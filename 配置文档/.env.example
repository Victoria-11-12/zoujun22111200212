# ========================================
# 数据库配置
# ========================================

# MySQL 数据库主机地址
DB_HOST=localhost

# 数据库端口（默认3306）
DB_PORT=3306

# 数据库名称
DB_NAME=movie_db

# 管理员数据库用户名（读写权限）
DB_USER=root

# 管理员数据库密码
DB_PASS=your_password_here

# 只读数据库用户名（普通用户使用）
DB_USER_READONLY=readonly_user

# 只读数据库密码
DB_PASS_READONLY=readonly_password_here


# ========================================
# LLM API 配置
# ========================================

# API 基础地址（支持 OpenAI 兼容的 API）
# DeepSeek: https://api.deepseek.com
# OpenAI: https://api.openai.com/v1
# 其他兼容服务请填写对应的 API 地址
API_BASE=https://api.deepseek.com

# API 密钥
API_KEY=your_api_key_here

# 对话模型名称
# DeepSeek: deepseek-chat
# OpenAI: gpt-4, gpt-3.5-turbo 等
MODEL_NAME=deepseek-chat


# ========================================
# 评估模型配置（数据分析师模块）
# ========================================

# 评估 API 密钥（可与上面 API_KEY 相同）
EVAL_API_KEY=your_eval_api_key_here

# 评估模型名称
# DeepSeek: deepseek-reasoner
# OpenAI: gpt-4 等
EVAL_MODEL_NAME=deepseek-reasoner


# ========================================
# JWT 配置（Node.js 服务）
# ========================================

# JWT 密钥（请使用随机字符串）
JWT_SECRET=your_jwt_secret_key_here

# JWT 过期时间（单位：小时，默认24小时）
JWT_EXPIRES_IN=24


# ========================================
# 服务端口配置
# ========================================

# Node.js 服务端口
NODE_PORT=3000

# Flask 服务端口
FLASK_PORT=5000

# FastAPI 服务端口
FASTAPI_PORT=8000


# ========================================
# Docker 配置（CodeAct Agent 沙箱）
# ========================================

# Docker 镜像名称（用于 pyecharts 绘图沙箱）
DOCKER_IMAGE=pyecharts-sandbox

# Docker 内存限制（单位：MB）
DOCKER_MEMORY_LIMIT=256

# Docker 执行超时时间（单位：秒）
DOCKER_TIMEOUT=30
