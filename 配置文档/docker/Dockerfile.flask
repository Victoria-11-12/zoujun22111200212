# ========================================
# Flask 服务 Dockerfile
# 算法服务：票房预测、黑马推荐、机器学习模型
# ========================================

FROM python:3.10-slim

# 设置工作目录
WORKDIR /app

# 安装系统依赖
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    libgomp1 \
    && rm -rf /var/lib/apt/lists/*

# 安装 Python 依赖
COPY Flask/requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

# 复制应用代码和模型文件
COPY Flask/ ./

# 暴露端口
EXPOSE 5000

# 启动命令
CMD ["python", "app2.py"]
